{
  "info": {
    "name": "mTLS + JWT API",
    "description": "Full flow: JWT assertion → access_token → protected resources.\n\nSetup:\n1. Postman Settings → Certificates → Add Certificate:\n   - Host: localhost, Port: 8443\n   - CRT: certs/client.crt  KEY: certs/client.key  CA: certs/ca.crt\n2. Set collection variables:\n   - jwt_bearer_private_key: paste full contents of certs/client.key\n   - jwt_bearer_username: sgummalla@exp-cloud.org\n3. Run requests in order.\n\nAll requests go through https://localhost:8443 (single mTLS port).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://localhost:8443",
      "type": "string"
    },
    {
      "key": "jwt_bearer_private_key",
      "value": "PASTE_CONTENTS_OF_client.key_HERE",
      "type": "string"
    },
    {
      "key": "jwt_bearer_issuer",
      "value": "postman-client",
      "type": "string"
    },
    {
      "key": "jwt_bearer_username",
      "value": "sgummalla@exp-cloud.org",
      "type": "string"
    },
    {
      "key": "cc_client_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "cc_client_secret",
      "value": "",
      "type": "string"
    },
    {
      "key": "assertion",
      "value": "",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "patient_id",
      "value": "pat-001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1 — POST /auth/token  (JWT assertion → access_token)",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/token",
        "description": "JWT bearer token endpoint — mTLS not required.\nThe collection pre-request script auto-generates the JWT assertion and calls this endpoint automatically before any other request.",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"grant_type\": \"urn:ietf:params:oauth:grant-type:jwt-bearer\",\n  \"assertion\": \"{{assertion}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Generate JWT assertion for the jwt-bearer token request.",
              "// Collection-level script skips /auth/token so we build it here.",
              "",
              "if (typeof navigator === 'undefined') { navigator = { appName: 'postman' }; }",
              "if (typeof window   === 'undefined') { window   = {}; }",
              "",
              "pm.sendRequest('https://kjur.github.io/jsrsasign/jsrsasign-latest-all-min.js', (err, res) => {",
              "  if (err) { throw new Error('Failed to load jsrsasign: ' + err); }",
              "  eval(res.text());",
              "",
              "  const rawKey    = pm.collectionVariables.get('jwt_bearer_private_key');",
              "  const username  = pm.collectionVariables.get('jwt_bearer_username');",
              "  const baseUrl   = pm.collectionVariables.get('base_url');",
              "  const now       = Math.floor(Date.now() / 1000);",
              "",
              "  // Normalize key — Postman stores newlines as literal \\n",
              "  const privateKeyPem = rawKey.replace(/\\\\n/g, '\\n').trim();",
              "",
              "  // Parse key object — handles PKCS8 and RSA formats",
              "  let keyObj;",
              "  try {",
              "    keyObj = KEYUTIL.getKey(privateKeyPem);",
              "  } catch(e) {",
              "    throw new Error('Failed to parse private key: ' + e.message + ' — check private_key variable');",
              "  }",
              "",
              "  const header  = { alg: 'RS256', typ: 'JWT' };",
              "  const payload = {",
              "    iss:      pm.collectionVariables.get('jwt_bearer_issuer'),",
              "    sub:      'postman-client',",
              "    aud:      baseUrl,",
              "    iat:      now,",
              "    exp:      now + 300,",
              "    jti:      'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {",
              "      const r = Math.random() * 16 | 0;",
              "      return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);",
              "    }),",
              "    username: username",
              "  };",
              "",
              "  const assertion = KJUR.jws.JWS.sign('RS256', JSON.stringify(header), JSON.stringify(payload), keyObj);",
              "",
              "  pm.collectionVariables.set('assertion', assertion);",
              "  console.log('✅ Assertion generated for:', username);",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns access_token', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.access_token).to.be.a('string');",
              "  pm.expect(body.token_type).to.eql('Bearer');",
              "  pm.expect(body.expires_in).to.eql(3600);",
              "  pm.collectionVariables.set('access_token', body.access_token);",
              "  console.log('✅ access_token saved');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "1b — POST /auth/token  (client_credentials)",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/token",
        "description": "Get a system-level token using client_id + client_secret.\nRun POST /clients/register first to get credentials.\nThe collection pre-request script skips auto-token for this request.",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"grant_type\": \"client_credentials\",\n  \"client_id\": \"{{cc_client_id}}\",\n  \"client_secret\": \"{{cc_client_secret}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns client_credentials token', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.access_token).to.be.a('string');",
              "  pm.expect(body.scope).to.eql('api:full');",
              "  const payload = JSON.parse(atob(body.access_token.split('.')[1]));",
              "  pm.expect(payload.type).to.eql('client_credentials_token');",
              "  pm.expect(payload.role).to.eql('admin');",
              "  pm.collectionVariables.set('access_token', body.access_token);",
              "  console.log('✅ client_credentials token — clientId:', payload.clientId);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "1c — POST /auth/token  (JWT assertion — form-urlencoded)",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/token",
        "description": "Same as request 1 but sends the body as application/x-www-form-urlencoded instead of JSON.\nUseful for OAuth clients that require form-encoded token requests (e.g. Salesforce).",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "grant_type",
              "value": "urn:ietf:params:oauth:grant-type:jwt-bearer",
              "type": "text"
            },
            {
              "key": "assertion",
              "value": "{{assertion}}",
              "type": "text"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Generate JWT assertion — same as request 1.",
              "if (typeof navigator === 'undefined') { navigator = { appName: 'postman' }; }",
              "if (typeof window   === 'undefined') { window   = {}; }",
              "",
              "pm.sendRequest('https://kjur.github.io/jsrsasign/jsrsasign-latest-all-min.js', (err, res) => {",
              "  if (err) { throw new Error('Failed to load jsrsasign: ' + err); }",
              "  eval(res.text());",
              "",
              "  const rawKey   = pm.collectionVariables.get('jwt_bearer_private_key');",
              "  const username = pm.collectionVariables.get('jwt_bearer_username');",
              "  const baseUrl  = pm.collectionVariables.get('base_url');",
              "  const now      = Math.floor(Date.now() / 1000);",
              "  const privateKeyPem = rawKey.replace(/\\\\n/g, '\\n').trim();",
              "",
              "  let keyObj;",
              "  try { keyObj = KEYUTIL.getKey(privateKeyPem); }",
              "  catch(e) { throw new Error('Failed to parse private key: ' + e.message); }",
              "",
              "  const header  = { alg: 'RS256', typ: 'JWT' };",
              "  const payload = {",
              "    iss:      pm.collectionVariables.get('jwt_bearer_issuer'),",
              "    sub:      'postman-client',",
              "    aud:      baseUrl,",
              "    iat:      now,",
              "    exp:      now + 300,",
              "    jti:      'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {",
              "      const r = Math.random() * 16 | 0;",
              "      return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);",
              "    }),",
              "    username: username",
              "  };",
              "",
              "  const assertion = KJUR.jws.JWS.sign('RS256', JSON.stringify(header), JSON.stringify(payload), keyObj);",
              "  pm.collectionVariables.set('assertion', assertion);",
              "  console.log('✅ Assertion generated for:', username);",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns access_token', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.access_token).to.be.a('string');",
              "  pm.expect(body.token_type).to.eql('Bearer');",
              "  pm.collectionVariables.set('access_token', body.access_token);",
              "  console.log('✅ access_token saved (form-urlencoded)');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "1d — POST /auth/token  (client_credentials — form-urlencoded)",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/token",
